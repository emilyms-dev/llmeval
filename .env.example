# Copy this file to .env and fill in your values.
# Never commit .env to version control.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Path to the SQLite database file (default: ./llmeval.db)
LLMEVAL_DB_PATH=./llmeval.db

# Model used for LLM-as-judge scoring when not specified in the suite YAML
LLMEVAL_JUDGE_MODEL=claude-sonnet-4-20250514

# Set to 1 to run integration tests that make real API calls
RUN_INTEGRATION_TESTS=0

# ---------------------------------------------------------------------------
# Dashboard server security (llmeval serve)
# ---------------------------------------------------------------------------

# Bearer token required on POST /api/runs and POST /api/runs/{id}/cancel.
# When unset, the server runs in open mode (local dev only — see Security docs).
LLMEVAL_API_TOKEN=

# Comma-separated list of allowed CORS origins (default: http://localhost:5173).
LLMEVAL_CORS_ORIGIN=http://localhost:5173

# Directory that suite_path values must reside in (default: current directory).
# Prevents path-traversal attacks via POST /api/runs.
LLMEVAL_SUITES_DIR=.
