# Copy this file to .env and fill in your values.
# Never commit .env to version control.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Path to the SQLite database file (default: ./llmeval.db)
LLMEVAL_DB_PATH=./llmeval.db

# Model used for LLM-as-judge scoring
LLMEVAL_JUDGE_MODEL=claude-sonnet-4-20250514

# Set to 1 to run integration tests that make real API calls
RUN_INTEGRATION_TESTS=0
